{
	"name": "blocks-for-leaflet-map",
	"version": "0.10.0",
	"description": "A dynamic block that renders Leaflet Map shortcodes from block attributes.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --webpack-copy-php --blocks-manifest",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "cd ../../.. && rm -f blocks-for-leaflet-map-*.zip && wp dist-archive wp-content/plugins/blocks-for-leaflet-map . --filename-format=\"{name}-{version}\"",
		"start": "wp-scripts start --webpack-copy-php --blocks-manifest",
		"make-pot": "wp i18n make-pot . languages/blocks-for-leaflet-map.pot --domain=blocks-for-leaflet-map --exclude=node_modules,vendor,build",
		"test": "wp-scripts test-unit-js"
	},
	"dependencies": {
		"@wordpress/block-editor": "latest",
		"@wordpress/blocks": "latest",
		"@wordpress/i18n": "latest"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.8.0"
	}
}
