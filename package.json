{
	"name": "cartoblocks-for-leaflet",
	"version": "1.2.0",
	"description": "A dynamic block that renders Leaflet Map shortcodes from block attributes.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --webpack-copy-php --blocks-manifest && node bin/harden-blocks-manifest.js",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "cd ../../.. && rm -f cartoblocks-for-leaflet-*.zip && wp dist-archive wp-content/plugins/cartoblocks-for-leaflet . --filename-format=\"{name}-{version}\"",
		"start": "wp-scripts start --webpack-copy-php --blocks-manifest",
		"make-pot": "wp i18n make-pot . languages/cartoblocks-for-leaflet.pot --domain=cartoblocks-for-leaflet --exclude=node_modules,vendor,build",
		"test": "wp-scripts test-unit-js"
	},
	"dependencies": {
		"@wordpress/block-editor": "^15.16.0",
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/i18n": "^6.16.0"
	},
	"devDependencies": {
		"@wordpress/scripts": "^31.8.0"
	}
}
