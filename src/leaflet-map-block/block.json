{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blocks-for-leaflet-map/leaflet-map-block",
	"version": "0.3.12",
	"title": "Leaflet Map Block",
	"category": "embed",
	"icon": "location-alt",
	"description": "Embed an interactive Leaflet map using the Leaflet Map plugin shortcodes.",
	"keywords": ["map", "leaflet", "location", "embed"],
	"example": {
		"attributes": {
			"lat": 37.1773,
			"lng": -3.5986,
			"zoom": 13,
			"height": "400px"
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"lat": {
			"type": "number",
			"default": 37.1773
		},
		"lng": {
			"type": "number",
			"default": -3.5986
		},
		"zoom": {
			"type": "number",
			"default": 13
		},
		"height": {
			"type": "string",
			"default": "400px"
		},
		"width": {
			"type": "string",
			"default": "100%"
		},
		"scrollWheelZoom": {
			"type": "boolean",
			"default": false
		},
		"zoomControl": {
			"type": "boolean",
			"default": true
		},
		"fitMarkers": {
			"type": "boolean",
			"default": false
		},
		"attribution": {
			"type": "string",
			"default": ""
		},
		"showScale": {
			"type": "boolean",
			"default": false
		},
		"dragging": {
			"type": "string",
			"default": ""
		},
		"keyboard": {
			"type": "string",
			"default": ""
		},
		"doubleClickZoom": {
			"type": "string",
			"default": ""
		},
		"boxZoom": {
			"type": "string",
			"default": ""
		},
		"closePopupOnClick": {
			"type": "string",
			"default": ""
		},
		"tap": {
			"type": "string",
			"default": ""
		},
		"inertia": {
			"type": "string",
			"default": ""
		},
		"minZoom": {
			"type": "string",
			"default": ""
		},
		"maxZoom": {
			"type": "string",
			"default": ""
		},
		"maxBounds": {
			"type": "string",
			"default": ""
		},
		"tileurl": {
			"type": "string",
			"default": ""
		},
		"tilesize": {
			"type": "string",
			"default": ""
		},
		"subdomains": {
			"type": "string",
			"default": ""
		},
		"mapid": {
			"type": "string",
			"default": ""
		},
		"accesstoken": {
			"type": "string",
			"default": ""
		},
		"zoomoffset": {
			"type": "string",
			"default": ""
		},
		"nowrap": {
			"type": "string",
			"default": ""
		},
		"detectretina": {
			"type": "string",
			"default": ""
		},
		"address": {
			"type": "string",
			"default": ""
		},
		"markers": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"lat":     { "type": "number" },
					"lng":     { "type": "number" },
					"title":   { "type": "string" },
					"content": { "type": "string" }
				}
			}
		}
	},
	"textdomain": "blocks-for-leaflet-map",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
