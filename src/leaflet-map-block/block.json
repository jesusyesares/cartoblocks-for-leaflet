{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blocks-for-leaflet-map/leaflet-map-block",
	"version": "1.0.5",
	"title": "Leaflet Map Block",
	"category": "embed",
	"icon": "location-alt",
	"description": "Embed an interactive Leaflet map using the Leaflet Map plugin shortcodes.",
	"keywords": [ "map", "leaflet", "location", "embed" ],
	"example": {
		"attributes": {
			"lat": 37.1773,
			"lng": -3.5986,
			"zoom": 13,
			"height": "400px"
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"lat": {
			"type": "number",
			"default": 37.1773
		},
		"lng": {
			"type": "number",
			"default": -3.5986
		},
		"zoom": {
			"type": "number",
			"default": 13
		},
		"height": {
			"type": "string",
			"default": "400px"
		},
		"width": {
			"type": "string",
			"default": "100%"
		},
		"scrollWheelZoom": {
			"type": "boolean",
			"default": false
		},
		"zoomControl": {
			"type": "boolean",
			"default": true
		},
		"fitMarkers": {
			"type": "boolean",
			"default": false
		},
		"attribution": {
			"type": "string",
			"default": ""
		},
		"showScale": {
			"type": "boolean",
			"default": false
		},
		"dragging": {
			"type": "string",
			"default": ""
		},
		"keyboard": {
			"type": "string",
			"default": ""
		},
		"doubleClickZoom": {
			"type": "string",
			"default": ""
		},
		"boxZoom": {
			"type": "string",
			"default": ""
		},
		"closePopupOnClick": {
			"type": "string",
			"default": ""
		},
		"tap": {
			"type": "string",
			"default": ""
		},
		"inertia": {
			"type": "string",
			"default": ""
		},
		"minZoom": {
			"type": "string",
			"default": ""
		},
		"maxZoom": {
			"type": "string",
			"default": ""
		},
		"maxBounds": {
			"type": "string",
			"default": ""
		},
		"tileurl": {
			"type": "string",
			"default": ""
		},
		"tilesize": {
			"type": "string",
			"default": ""
		},
		"subdomains": {
			"type": "string",
			"default": ""
		},
		"mapid": {
			"type": "string",
			"default": ""
		},
		"accesstoken": {
			"type": "string",
			"default": ""
		},
		"zoomoffset": {
			"type": "string",
			"default": ""
		},
		"nowrap": {
			"type": "string",
			"default": ""
		},
		"detectretina": {
			"type": "string",
			"default": ""
		},
		"address": {
			"type": "string",
			"default": ""
		},
		"wmsEnabled": {
			"type": "boolean",
			"default": false
		},
		"wmsSource": {
			"type": "string",
			"default": ""
		},
		"wmsLayer": {
			"type": "string",
			"default": ""
		},
		"wmsCrs": {
			"type": "string",
			"default": ""
		},
		"imageMap": {
			"type": "boolean",
			"default": false
		},
		"imageSrc": {
			"type": "string",
			"default": ""
		},
		"imageX": {
			"type": "number",
			"default": 0
		},
		"imageY": {
			"type": "number",
			"default": 0
		},
		"imageZoom": {
			"type": "number",
			"default": 0
		},
		"markers": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"lat": { "type": "number" },
					"lng": { "type": "number" },
					"title": { "type": "string" },
					"content": { "type": "string" },
					"alt": { "type": "string" },
					"visible": { "type": "boolean" },
					"draggable": { "type": "boolean" },
					"opacity": { "type": "number" },
					"zIndexOffset": { "type": "integer" },
					"useCustomIcon": { "type": "boolean", "default": false },
					"iconUrl": { "type": "string", "default": "" },
					"iconWidth": { "type": [ "number", "null" ] },
					"iconHeight": { "type": [ "number", "null" ] },
					"iconAnchorX": { "type": [ "number", "null" ] },
					"iconAnchorY": { "type": [ "number", "null" ] },
					"popupAnchorX": { "type": [ "number", "null" ] },
					"popupAnchorY": { "type": [ "number", "null" ] },
					"useShadow": { "type": "boolean", "default": false },
					"shadowUrl": { "type": "string", "default": "" },
					"shadowWidth": { "type": [ "number", "null" ] },
					"shadowHeight": { "type": [ "number", "null" ] },
					"shadowAnchorX": { "type": [ "number", "null" ] },
					"shadowAnchorY": { "type": [ "number", "null" ] },
					"iconOriginalWidth": { "type": [ "number", "null" ] },
					"iconOriginalHeight": { "type": [ "number", "null" ] },
					"lockIconAspectRatio": {
						"type": "boolean",
						"default": true
					},
					"shadowOriginalWidth": { "type": [ "number", "null" ] },
					"shadowOriginalHeight": { "type": [ "number", "null" ] },
					"lockShadowAspectRatio": {
						"type": "boolean",
						"default": true
					},
					"useSvgMarker": { "type": "boolean", "default": false },
					"svgBackground": { "type": "string", "default": "" },
					"svgIconClass": { "type": "string", "default": "" },
					"svgColor": { "type": "string", "default": "" }
				}
			}
		},
		"lines": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"type": { "type": "string", "default": "line" },
					"points": {
						"type": "array",
						"default": [],
						"items": {
							"type": "object",
							"properties": {
								"lat": { "type": "number", "default": 0 },
								"lng": { "type": "number", "default": 0 }
							}
						}
					},
					"fitbounds": { "type": "boolean", "default": false },
					"color": { "type": "string", "default": "" },
					"weight": { "type": [ "number", "null" ], "default": null },
					"opacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"dashArray": { "type": "string", "default": "" },
					"classname": { "type": "string", "default": "" },
					"fill": { "type": "boolean", "default": false },
					"fillColor": { "type": "string", "default": "" },
					"fillOpacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"popup": { "type": "string", "default": "" },
					"visible": { "type": "boolean", "default": false }
				}
			}
		},
		"circles": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"lat": { "type": [ "number", "null" ], "default": null },
					"lng": { "type": [ "number", "null" ], "default": null },
					"radius": { "type": "number", "default": 1000 },
					"fitbounds": { "type": "boolean", "default": false },
					"color": { "type": "string", "default": "" },
					"weight": { "type": [ "number", "null" ], "default": null },
					"opacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"dashArray": { "type": "string", "default": "" },
					"classname": { "type": "string", "default": "" },
					"fill": { "type": "boolean", "default": false },
					"fillColor": { "type": "string", "default": "" },
					"fillOpacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"popup": { "type": "string", "default": "" },
					"visible": { "type": "boolean", "default": false }
				}
			}
		},
		"layers": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"type": { "type": "string", "default": "geojson" },
					"src": { "type": "string", "default": "" },
					"fitbounds": { "type": "boolean", "default": false },
					"popupText": { "type": "string", "default": "" },
					"popupProperty": { "type": "string", "default": "" },
					"tableView": { "type": "boolean", "default": false },
					"color": { "type": "string", "default": "" },
					"weight": { "type": [ "number", "null" ], "default": null },
					"opacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"dashArray": { "type": "string", "default": "" },
					"classname": { "type": "string", "default": "" },
					"fill": { "type": "boolean", "default": false },
					"fillColor": { "type": "string", "default": "" },
					"fillOpacity": {
						"type": [ "number", "null" ],
						"default": null
					},
					"useCustomIcon": { "type": "boolean", "default": false },
					"iconUrl": { "type": "string", "default": "" },
					"iconWidth": { "type": [ "number", "null" ] },
					"iconHeight": { "type": [ "number", "null" ] },
					"iconAnchorX": { "type": [ "number", "null" ] },
					"iconAnchorY": { "type": [ "number", "null" ] },
					"popupAnchorX": { "type": [ "number", "null" ] },
					"popupAnchorY": { "type": [ "number", "null" ] },
					"iconOriginalWidth": { "type": [ "number", "null" ] },
					"iconOriginalHeight": { "type": [ "number", "null" ] },
					"lockIconAspectRatio": {
						"type": "boolean",
						"default": true
					}
				}
			}
		},
		"overlays": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"type": { "type": "string", "default": "image" },
					"src": { "type": "string", "default": "" },
					"bounds": { "type": "string", "default": "" },
					"opacity": { "type": [ "number", "null" ], "default": null },
					"interactive": { "type": "boolean", "default": false },
					"alt": { "type": "string", "default": "" },
					"zIndex": { "type": [ "number", "null" ], "default": null },
					"classname": { "type": "string", "default": "" },
					"keepAspectRatio": { "type": "boolean", "default": true }
				}
			}
		}
	},
	"textdomain": "blocks-for-leaflet-map",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
